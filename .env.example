# БД (async URL для приложения; sync — для alembic)
DATABASE_URL=postgresql+asyncpg://predictions:predictions@localhost:5432/predictions_db
DATABASE_URL_SYNC=postgresql://predictions:predictions@localhost:5432/predictions_db

# AI
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# AI_PROMPT_TEMPLATE=prompts/ai_match_summary.txt

# Telegram (бот + алерты в admin chat)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=123456789

# API
ADMIN_API_KEY=
PORT=8000

# Парсер (переопределяют config.ini при необходимости)
REQUIRE_PROXY=true
HEADLESS=true
